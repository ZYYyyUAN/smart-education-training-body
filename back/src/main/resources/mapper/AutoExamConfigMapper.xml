<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atguigu.java.ai.langchain4j.mapper.AutoExamConfigMapper">

    <resultMap id="BaseResultMap" type="com.atguigu.java.ai.langchain4j.entity.AutoExamConfig">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="course_id" property="courseId" jdbcType="BIGINT"/>
        <result column="teacher_id" property="teacherId" jdbcType="BIGINT"/>
        <result column="config_name" property="configName" jdbcType="VARCHAR"/>
        <result column="total_questions" property="totalQuestions" jdbcType="INTEGER"/>
        <result column="question_distribution" property="questionDistribution" jdbcType="VARCHAR"/>
        <result column="difficulty_distribution" property="difficultyDistribution" jdbcType="VARCHAR"/>
        <result column="knowledge_point_weights" property="knowledgePointWeights" jdbcType="VARCHAR"/>
        <result column="time_limit_minutes" property="timeLimitMinutes" jdbcType="INTEGER"/>
        <result column="ai_prompt_template" property="aiPromptTemplate" jdbcType="VARCHAR"/>
        <result column="is_active" property="isActive" jdbcType="BOOLEAN"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByCourseAndTeacher" resultMap="BaseResultMap">
        SELECT * FROM auto_exam_config
        WHERE course_id = #{courseId} AND teacher_id = #{teacherId}
        ORDER BY created_at DESC
    </select>

    <select id="selectActiveByCourseId" resultMap="BaseResultMap">
        SELECT * FROM auto_exam_config
        WHERE course_id = #{courseId} AND is_active = 1
        ORDER BY created_at DESC
    </select>

</mapper>
