<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atguigu.java.ai.langchain4j.mapper.AutoGeneratedExamMapper">

    <resultMap id="BaseResultMap" type="com.atguigu.java.ai.langchain4j.entity.AutoGeneratedExam">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="config_id" property="configId" jdbcType="BIGINT"/>
        <result column="exam_title" property="examTitle" jdbcType="VARCHAR"/>
        <result column="exam_description" property="examDescription" jdbcType="VARCHAR"/>
        <result column="generation_strategy" property="generationStrategy" jdbcType="VARCHAR"/>
        <result column="ai_model_used" property="aiModelUsed" jdbcType="VARCHAR"/>
        <result column="generation_prompt" property="generationPrompt" jdbcType="VARCHAR"/>
        <result column="generation_metadata" property="generationMetadata" jdbcType="VARCHAR"/>
        <result column="quality_score" property="qualityScore" jdbcType="DECIMAL"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="reviewed_at" property="reviewedAt" jdbcType="TIMESTAMP"/>
        <result column="published_at" property="publishedAt" jdbcType="TIMESTAMP"/>
        <result column="created_by" property="createdBy" jdbcType="BIGINT"/>
    </resultMap>

    <select id="selectByConfigId" resultMap="BaseResultMap">
        SELECT * FROM auto_generated_exam
        WHERE config_id = #{configId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByTeacherId" resultMap="BaseResultMap">
        SELECT * FROM auto_generated_exam
        WHERE created_by = #{teacherId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM auto_generated_exam
        WHERE status = #{status}
        ORDER BY created_at DESC
    </select>

</mapper>
