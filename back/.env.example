# ============================================================
# 生产环境所需环境变量清单
# 复制此文件为 .env 并填入真实值
# 开发环境无需设置（application.properties 内置了默认值）
# ============================================================

# ---- 数据库 ----
DB_URL=jdbc:mysql://<host>:3306/xiaozhi?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false
DB_USERNAME=root
DB_PASSWORD=<your_db_password>

# ---- MongoDB ----
MONGODB_URI=mongodb://<user>:<password>@<host>:27017/chat_memory_db4?authSource=admin

# ---- Neo4j ----
NEO4J_URI=neo4j://<host>:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your_neo4j_password>

# ---- 通义千问 (DashScope) ----
TONGYI_API_KEY=<your_tongyi_api_key>

# ---- 阿里云 OSS ----
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=<your_aliyun_access_key_id>
ALIYUN_OSS_ACCESS_KEY_SECRET=<your_aliyun_access_key_secret>
ALIYUN_OSS_BUCKET_NAME=<your_oss_bucket_name>

# ---- 科大讯飞语音 ----
XFYUN_APP_ID=<your_xfyun_app_id>
XFYUN_API_KEY=<your_xfyun_api_key>

# ---- 科大讯飞 TTS (语音合成) ----
XFYUN_TTS_API_KEY=<your_xfyun_tts_api_key>
XFYUN_TTS_API_SECRET=<your_xfyun_tts_api_secret>

# ---- 科大讯飞 IAT (语音识别) ----
XFYUN_IAT_APP_ID=<your_xfyun_iat_app_id>
XFYUN_IAT_API_KEY=<your_xfyun_iat_api_key>
XFYUN_IAT_API_SECRET=<your_xfyun_iat_api_secret>

# ---- 科大讯飞 OCR ----
XUNFEI_OCR_APP_ID=<your_xunfei_ocr_app_id>
XUNFEI_OCR_API_KEY=<your_xunfei_ocr_api_key>
XUNFEI_OCR_API_SECRET=<your_xunfei_ocr_api_secret>

# ---- Pinecone 向量存储 ----
PINECONE_API_KEY=<your_pinecone_api_key>

# ---- JWT ----
JWT_SECRET=<your_jwt_secret_at_least_256_bits>

# ---- 服务端口 ----
SERVER_PORT=8080

# ============================================================
# Docker Compose 部署所需变量
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=<your_mysql_root_password>
MYSQL_DATABASE=xiaozhi
MYSQL_USER=xiaozhi
MYSQL_PASSWORD=<your_mysql_password>

# ---- MongoDB ----
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=<your_mongo_root_password>
MONGO_DATABASE=chat_memory_db4
MONGO_USER=xiaozhi
MONGO_PASSWORD=<your_mongo_password>

